# Configuración del Sistema de Facturación

# Clave secreta para sesiones (cambiar en producción)
SECRET_KEY=tu-clave-secreta-muy-larga-y-aleatoria

# Configuración de Base de Datos MySQL
MYSQL_HOST=localhost
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DB=cafeteria_facturacion

# Ambiente
FLASK_ENV=development
FLASK_APP=app.py

# Notas:
# - MYSQL_HOST: dirección del servidor MySQL (localhost para local)
# - MYSQL_USER: usuario de MySQL (root por defecto)
# - MYSQL_PASSWORD: contraseña de MySQL (dejar vacío si no tiene)
# - MYSQL_DB: nombre de la base de datos a crear/usar
# - SECRET_KEY: debe ser una cadena larga y aleatoria (para cifrar sesiones)
